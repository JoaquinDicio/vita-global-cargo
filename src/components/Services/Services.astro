---
import Container from "../Container.astro";
import SectionHeader from "../SectionHeader.astro";
const { lang, t } = Astro.props;
---

<Container class="pt-24 md:pt-32 lg:pt-38 pb-16 md:pb-20 bg-white">
    <SectionHeader
        eyebrow={t.servicesSection.eyebrow}
        title={t.servicesSection.title}
        description={t.servicesSection.description}
    />

    <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6 mt-10"
    >
        <div class="h-75 bg-gray-200 rounded-xl"></div>
        <div class="h-75 bg-gray-200 rounded-xl"></div>
        <div class="h-75 bg-gray-200 rounded-xl"></div>
        <div class="h-75 bg-gray-200 rounded-xl"></div>
        <div class="h-75 bg-gray-200 rounded-xl"></div>

        <div class="h-75 bg-gray-200 rounded-xl"></div>
        <div class="h-75 bg-gray-200 rounded-xl"></div>
        <div class="h-75 bg-gray-200 rounded-xl"></div>
        <div class="h-75 bg-gray-200 rounded-xl"></div>
        <div class="h-75 bg-gray-200 rounded-xl"></div>
    </div>
</Container>
