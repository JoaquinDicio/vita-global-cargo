---
import Container from "./Container.astro";
const { t } = Astro.props;
---

<Container class="bg-(--color-primary)">
        <div
            class="py-10 flex flex-col md:flex-row items-center justify-between gap-10 md:gap-16"
        >
            <div class="max-w-md p-5 text-center md:text-left">
                <h3
                    class="text-white text-[24px] md:text-[28px] font-bold leading-tight"
                >
                    {t.experienceBanner.title}
                </h3>

                <p class="mt-4 text-white/90 text-[14px] leading-relaxed">
                    {t.experienceBanner.description}
                </p>
            </div>

            <div class="w-full md:w-auto">
                <!-- Mobile -->
                <div
                    class="grid grid-cols-3 divide-x divide-white/30 md:hidden text-center"
                >
                    <div class="px-2">
                        <h4
                            class="text-(--color-accent) text-[32px] font-bold leading-none"
                        >
                            {t.experienceBanner.stats.years.value}
                        </h4>

                        <p class="mt-2 text-white text-[14px] leading-tight">
                            {t.experienceBanner.stats.years.label}
                        </p>
                    </div>

                    <div class="px-2">
                        <h4
                            class="text-(--color-accent) text-[18px] font-bold leading-none"
                        >
                            {t.experienceBanner.stats.network.value}
                        </h4>

                        <p class="mt-2 text-white text-[14px] leading-tight">
                            {t.experienceBanner.stats.network.label}
                        </p>
                    </div>

                    <div class="px-2">
                        <h4
                            class="text-(--color-accent) text-[18px] font-bold leading-none"
                        >
                            {t.experienceBanner.stats.response.value}
                        </h4>

                        <p class="mt-2 text-white text-[14px] leading-tight">
                            {t.experienceBanner.stats.response.label}
                        </p>
                    </div>
                </div>

                <!-- Desktop -->
                <div class="hidden md:flex items-center">
                    <div class="px-8">
                        <h4
                            class="text-(--color-accent) text-[40px] font-bold leading-none"
                        >
                            {t.experienceBanner.stats.years.value}
                        </h4>

                        <p class="mt-2 text-white text-[14px] leading-tight">
                            {t.experienceBanner.stats.years.label}
                        </p>
                    </div>

                    <div class="h-20 w-px bg-white/30"></div>

                    <div class="px-8">
                        <h4
                            class="text-(--color-accent) text-[24px] font-bold leading-none"
                        >
                            {t.experienceBanner.stats.network.value}
                        </h4>

                        <p class="mt-2 text-white text-[14px] leading-tight">
                            {t.experienceBanner.stats.network.label}
                        </p>
                    </div>

                    <div class="h-20 w-px bg-white/30"></div>

                    <div class="px-8">
                        <h4
                            class="text-(--color-accent) text-[24px] font-bold leading-none"
                        >
                            {t.experienceBanner.stats.response.value}
                        </h4>

                        <p class="mt-2 text-white text-[14px] leading-tight">
                            {t.experienceBanner.stats.response.label}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </Container>