---
import Container from "../Container.astro";
import SectionHeader from "../SectionHeader.astro";

import plane from "../../assets/icons/plane.svg";
import boat from "../../assets/icons/boat.svg";
import truck from "../../assets/icons/truck.svg";
import courier from "../../assets/icons/package.svg";

const { lang: t } = Astro.props;

interface Service {
    title: string;
    subtitle: string;
}

const icons = [courier, plane, truck, boat];

const services = (t.contact.services as Service[]).map((service, index) => ({
    ...service,
    icon: icons[index],
}));
---

<Container class="py-16 md:py-22">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-center">
        <!-- Columna izquierda -->
        <div class="text-center md:text-left">
            <SectionHeader
                text_color="light"
                align="left"
                eyebrow={t.contact.eyebrow}
                title={t.contact.title}
                description={t.contact.description}
            />

            <p class="mt-6 text-white font-semibold max-w-md mx-auto md:mx-0">
                {t.contact.highlight}
            </p>

            <!-- Desktop -->
            <div class="hidden md:grid grid-cols-2 gap-x-12 gap-y-8 mt-12">
                {
                    services.map((service) => (
                        <div class="flex items-center gap-4">
                            <img
                                src={service.icon.src}
                                alt={service.title}
                                class="w-[58px] h-[49px]"
                            />

                            <div>
                                <h3 class="text-white font-semibold">
                                    {service.title}
                                </h3>

                                <p class="text-white/70">{service.subtitle}</p>
                            </div>
                        </div>
                    ))
                }
            </div>

            <!-- Mobile -->
            <div class="md:hidden mt-12 overflow-hidden">
                <div class="flex w-max animate-marquee">
                    {
                        [...services, ...services].map((service) => (
                            <div class="flex items-center gap-4 px-8 shrink-0">
                                <img
                                    src={service.icon.src}
                                    alt={service.title}
                                    class="w-[58px] h-[49px]"
                                />

                                <div>
                                    <h3 class="text-white font-semibold whitespace-nowrap">
                                        {service.title}
                                    </h3>

                                    <p class="text-white/70 whitespace-nowrap">
                                        {service.subtitle}
                                    </p>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>

        <!-- Formulario -->
        <div class="w-full max-w-lg mx-auto md:ml-auto">
            <div
                class="bg-black/35 backdrop-blur-sm rounded-xl p-6 md:p-8 border border-white/10"
            >
                <h3 class="text-white text-[20px] font-bold leading-tight">
                    {t.contact.form.title}
                </h3>

                <div class="w-12 h-1 bg-(--color-accent) mt-4 mb-8"></div>

                <form class="space-y-3">
                    <div>
                        <label class="block text-white text-sm mb-2">
                            {t.contact.form.name}
                        </label>

                        <input
                            type="text"
                            class="w-full h-12 rounded border border-white/30 bg-transparent px-4 text-white"
                        />
                    </div>

                    <div>
                        <label class="block text-white text-sm mb-2">
                            {t.contact.form.email}
                        </label>

                        <input
                            type="email"
                            class="w-full h-12 rounded border border-white/30 bg-transparent px-4 text-white"
                        />
                    </div>

                    <div>
                        <label class="block text-white text-sm mb-2">
                            {t.contact.form.phone}
                        </label>

                        <input
                            type="text"
                            class="w-full h-12 rounded border border-white/30 bg-transparent px-4 text-white"
                        />
                    </div>

                    <div>
                        <label class="block text-white text-sm mb-2">
                            {t.contact.form.message}
                        </label>

                        <textarea
                            rows="5"
                            class="w-full rounded border border-white/30 bg-transparent px-4 py-3 text-white resize-none"
                        ></textarea>
                    </div>

                    <button
                        type="submit"
                        class="w-full h-10 rounded bg-(--color-accent) text-white font-semibold"
                    >
                        {t.contact.form.button}
                    </button>
                </form>
            </div>
        </div>
    </div>
</Container>
