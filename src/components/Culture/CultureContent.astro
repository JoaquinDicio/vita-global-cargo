---
import Container from "../Container.astro";
import SectionHeader from "../SectionHeader.astro";
---

<Container
    class="py-16 md:py-22 flex flex-col md:flex-row justify-between items-center md:items-start gap-12 md:gap-16"
>
    <div class="max-w-lg text-center md:text-left">
        <SectionHeader
            align="left"
            title="Las personas, nuestro motor"
            eyebrow="nuestra cultura"
            description="Creemos que la logística la hacen las personas. Por eso construimos relaciones basadas en el respeto, la confianza y el compromiso."
        />

        <p class="font-bold text-(--color-text) mt-5">
            Queremos que Vita Global Cargo sea una empresa donde los clientes
            quieran trabajar y las personas quieran permanecer.
        </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 w-full md:w-xl">
        <div class="aspect-square rounded bg-gray-200">1</div>
        <div class="aspect-square rounded bg-gray-200">2</div>
        <div class="aspect-square rounded bg-gray-200">3</div>
        <div class="aspect-square rounded bg-gray-200">4</div>
        <div class="aspect-square rounded bg-gray-200">5</div>
        <div class="aspect-square rounded bg-gray-200">6</div>
    </div>
</Container>
