---
interface Props {
    eyebrow: string;
    title: string;
    description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-3xl mx-auto text-center">
    <span
        class="block
            text-[16px]
            font-bold
            uppercase
            tracking-wide
            text-(--color-accent)"
    >
        {eyebrow}
    </span>

    <h2
        class="mt-3
            text-[28px]
            font-bold
            leading-tight
            text-(--color-black)"
    >
        {title}
    </h2>

    {
        description && (
            <p
                class="
                    mt-4
                    text-[16px]
                    leading-relaxed
                    text-black/70
                    max-w-2xl
                    mx-auto
                "
            >
                {description}
            </p>
        )
    }
</div>
