---
interface Props {
    eyebrow: string;
    title: string;
    description?: string;
    align?: "left" | "center";
}

const { eyebrow, title, description, align = "center" } = Astro.props;

const isCentered = align === "center";
---

<div
    class:list={["max-w-3xl", isCentered ? "mx-auto text-center" : "text-left"]}
>
    <span
        class="block text-[16px] font-bold uppercase tracking-wide text-(--color-accent)"
    >
        {eyebrow}
    </span>

    <h2 class="mt-3 text-[28px] font-bold leading-tight text-(--color-black)">
        {title}
    </h2>

    {
        description && (
            <p
                class:list={[
                    "mt-4 text-[16px] leading-relaxed text-black/70 max-w-2xl",
                    isCentered && "mx-auto",
                ]}
            >
                {description}
            </p>
        )
    }
</div>
