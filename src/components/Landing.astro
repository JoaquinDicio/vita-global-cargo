---
import Layout from "../layouts/Layout.astro";

import HeroContent from "./Hero/HeroContent.astro";
import HeroServices from "./Hero/HeroServices.astro";
import Services from "./Services/Services.astro";
import Container from "./Container.astro";
import ProcessContent from "./Process/ProcessContent.astro";
import CultureContent from "./Culture/CultureContent.astro";
import ContactContent from "./Contact/ContactContent.astro";

const { t, lang } = Astro.props;
---

<Layout t={t} lang={lang}>
    <section id="hero">
        <div
            class="bg-cover bg-center"
            style="background-image: url('/hero.png');"
        >
            <div
                class="bg-[linear-gradient(to_bottom,rgba(8,21,40,1)_0%,rgba(8,21,40,0.85)_45%,rgba(28,75,142,0.35)_100%)]
                md:bg-[linear-gradient(to_right,rgba(8,21,40,1)_0%,rgba(8,21,40,0.8)_30%,rgba(28,75,142,0.4)_55%,transparent_100%)]"
            >
                <HeroContent lang={lang} t={t} />
                <HeroServices lang={lang} t={t} />
            </div>
        </div>
    </section>

    <section id="services" class="bg-white">
        <Services lang={lang} t={t} />
    </section>

    <Container class="bg-(--color-primary)">
        <div
            class="py-10 flex flex-col md:flex-row items-center justify-between gap-10 md:gap-16"
        >
            <div class="max-w-md p-5 text-center md:text-left">
                <h3
                    class="text-white text-[24px] md:text-[28px] font-bold leading-tight"
                >
                    {t.experienceBanner.title}
                </h3>

                <p class="mt-4 text-white/90 text-[14px] leading-relaxed">
                    {t.experienceBanner.description}
                </p>
            </div>

            <div class="w-full md:w-auto">
                <!-- Mobile -->
                <div
                    class="grid grid-cols-3 divide-x divide-white/30 md:hidden text-center"
                >
                    <div class="px-2">
                        <h4
                            class="text-(--color-accent) text-[32px] font-bold leading-none"
                        >
                            {t.experienceBanner.stats.years.value}
                        </h4>

                        <p class="mt-2 text-white text-[14px] leading-tight">
                            {t.experienceBanner.stats.years.label}
                        </p>
                    </div>

                    <div class="px-2">
                        <h4
                            class="text-(--color-accent) text-[18px] font-bold leading-none"
                        >
                            {t.experienceBanner.stats.network.value}
                        </h4>

                        <p class="mt-2 text-white text-[14px] leading-tight">
                            {t.experienceBanner.stats.network.label}
                        </p>
                    </div>

                    <div class="px-2">
                        <h4
                            class="text-(--color-accent) text-[18px] font-bold leading-none"
                        >
                            {t.experienceBanner.stats.response.value}
                        </h4>

                        <p class="mt-2 text-white text-[14px] leading-tight">
                            {t.experienceBanner.stats.response.label}
                        </p>
                    </div>
                </div>

                <!-- Desktop -->
                <div class="hidden md:flex items-center">
                    <div class="px-8">
                        <h4
                            class="text-(--color-accent) text-[40px] font-bold leading-none"
                        >
                            {t.experienceBanner.stats.years.value}
                        </h4>

                        <p class="mt-2 text-white text-[14px] leading-tight">
                            {t.experienceBanner.stats.years.label}
                        </p>
                    </div>

                    <div class="h-20 w-px bg-white/30"></div>

                    <div class="px-8">
                        <h4
                            class="text-(--color-accent) text-[24px] font-bold leading-none"
                        >
                            {t.experienceBanner.stats.network.value}
                        </h4>

                        <p class="mt-2 text-white text-[14px] leading-tight">
                            {t.experienceBanner.stats.network.label}
                        </p>
                    </div>

                    <div class="h-20 w-px bg-white/30"></div>

                    <div class="px-8">
                        <h4
                            class="text-(--color-accent) text-[24px] font-bold leading-none"
                        >
                            {t.experienceBanner.stats.response.value}
                        </h4>

                        <p class="mt-2 text-white text-[14px] leading-tight">
                            {t.experienceBanner.stats.response.label}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </Container>

    <section id="process" class="bg-white">
        <ProcessContent lang={lang} t={t} />
    </section>

    <div class="bg-cover bg-center" style="background-image: url('/hero.png');">
        <div
            class="py-10
            bg-[linear-gradient(to_right,rgba(8,21,40,1)_0%,rgba(8,21,40,0.8)_30%,rgba(28,75,142,0.2)_50%,rgba(8,21,40,0.8)_70%,rgba(8,21,40,1)_100%)]
            max-md:bg-[rgba(8,21,40,0.75)]"
        >
            <Container
                class="text-center md:text-left flex md:flex-row flex-col md:items-center justify-center md:justify-between"
            >
                <div class="max-w-none md:max-w-sm">
                    <h3 class="font-bold text-[24px] mb-5">
                        {t.cta.title}
                    </h3>

                    <p class="text-[14px]">
                        {t.cta.description}
                    </p>
                </div>

                <a
                    href="#contact"
                    class="inline-flex mt-5 items-center bg-(--color-accent) justify-center text-[14px] px-6 py-4 rounded-md font-semibold text-white hover:bg-red-600 transition"
                >
                    {t.cta.button}
                </a>
            </Container>
        </div>
    </div>

    <section id="culture" class="bg-white">
        <CultureContent lang={lang} t={t} />
    </section>

    <section id="contact">
        <div
            class="bg-cover md:bg-center bg-top-center"
            style="background-image: url('/contact.png')"
        >
            <div
                class="bg-[linear-gradient(to_right,rgba(8,21,40,1)_0%,rgba(8,21,40,0.85)_30%,rgba(28,75,142,0.3)_55%,rgba(8,21,40,0.85)_70%,rgba(8,21,40,1)_100%)]"
            >
                <ContactContent lang={lang} t={t} />
            </div>
        </div>
    </section>
</Layout>
