---
import Container from "../Container.astro";
import SectionHeader from "../SectionHeader.astro";
import map from "../../assets/map.png";

interface Steps {
    title: string;
    description: string;
}

const STEPS: Steps[] = [
    {
        title: "Escuchamos",
        description:
            "Entendemos la operación, origen, destino y tipo de carga.",
    },
    {
        title: "Cotizamos",
        description: "Presentamos alternativas claras, viables y competitivas.",
    },
    {
        title: "Coordinamos",
        description: "Gestionamos cada etapa con comunicación directa",
    },
    {
        title: "Cumplimos",
        description:
            "Acompañamos hasta el cierre cuidando carga, tiempos y relación.",
    },
];
---

<Container class="min-h-screen py-22 bg-white">
    <SectionHeader
        eyebrow="CÓMO TRABAJAMOS EN VITA"
        title="Claridad desde el primer contacto"
        description="Buscamos que cada cliente tenga visibilidad, alternativas y acompañamiento real."
    />

    <div class="relative mt-16 max-w-5xl mx-auto">
        <div
            class="absolute top-10.25 left-[12%] right-[12%] h-0.5 bg-(--color-secondary)"
        >
        </div>

        <!-- steps -->
        <div class="relative grid grid-cols-4 gap-8">
            {
                STEPS.map((step, idx) => (
                    <div class="flex flex-col items-center text-center">
                        <div class="w-20.5 h-20.5 rounded-full bg-(--color-secondary) flex items-center justify-center z-10">
                            <span class="text-2xl font-bold">{idx + 1}</span>
                        </div>

                        <h3 class="mt-3 font-bold text-lg text-(--color-text)">
                            {step.title}
                        </h3>

                        <p class="mt-1 text-sm text-black/70 max-w-55">
                            {step.description}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
    <div class="flex justify-between text-(--color-text) mt-20">
        <img src={map.src} alt="mapa" />
        <div class="max-w-sm flex flex-col items-start gap-2">
            <h3 class="font-bold text-[24px]">
                Conectamos tu carga con el mundo
            </h3>
            <p class="text-[14px]">
                Contamos con convenios y una red de agentes estratégicos en los
                principales países para coordinar importaciones y exportaciones
                con eficiencia y seguridad
            </p>
            <a
                href="#contact"
                class="inline-flex mt-5 items-center justify-center border border-(--color-secondary) text-[14px] px-6 py-4 rounded-md font-semibold text-(--color-secondary) hover:bg-(--color-secondary) hover:text-white transition"
            >
                Hablar con un especialista
            </a>
        </div>
    </div>
</Container>
