---
const { t } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-(--color-primary) text-white">
    <div class="max-w-7xl mx-auto px-6 py-16">
        <div class="grid gap-12 lg:grid-cols-3">
            <!-- Marca -->
            <div>
                <img
                    src="/logo-white.svg"
                    alt="Vita Global Cargo"
                    class="h-12 w-auto mb-6"
                />

                <p class="max-w-sm text-sm leading-relaxed text-white/70">
                    {t.footer.description}
                </p>
            </div>

            <!-- Navegación -->
            <div>
                <h3 class="mb-4 font-semibold">
                    {t.footer.navigation.title}
                </h3>

                <ul class="space-y-3 text-sm text-white/70">
                    {
                        t.footer.navigation.links.map(
                            (link: { href: string; label: string }) => (
                                <li>
                                    <a href={link.href}>{link.label}</a>
                                </li>
                            ),
                        )
                    }
                </ul>
            </div>

            <!-- Contacto -->
            <div>
                <h3 class="mb-4 font-semibold">
                    {t.footer.contact.title}
                </h3>

                <ul class="space-y-3 text-sm text-white/70">
                    <li>{t.footer.contact.email}</li>
                    <li>{t.footer.contact.phone}</li>
                    <li>{t.footer.contact.location}</li>
                </ul>
            </div>
        </div>

        <div class="mt-12 border-t border-white/10 pt-6">
            <p class="text-center text-sm text-white/50">
                © {year} Vita Global Cargo. {t.footer.copyright}
            </p>
        </div>
    </div>
</footer>
