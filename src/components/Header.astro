---
const links = [
    { href: "#services", label: "Servicios" },
    { href: "#culture", label: "Nuestra Cultura" },
    { href: "#identity", label: "Identidad" },
    { href: "#contact", label: "Contacto" },
];
---

<header
    id="site-header"
    class="fixed top-0 left-0 w-full z-50 transition-colors duration-300"
>
    <div class="max-w-7xl mx-auto px-6 md:px-12">
        <div class="h-20 md:h-28 flex items-center justify-between">
            <!-- Logo -->
            <a href="/">
                <img
                    src="/logo-white.svg"
                    alt="Vita Global Cargo"
                    class="h-10 md:h-14 w-auto"
                />
            </a>

            <!-- Desktop -->
            <nav class="hidden lg:block">
                <ul class="flex items-center gap-16">
                    {
                        links.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="text-white font-medium hover:opacity-80 transition text-[14px]"
                                >
                                    {link.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>

            <a
                href="#contact"
                class="hidden lg:flex items-center justify-center bg-(--color-accent) text-white font-semibold px-10 py-4 rounded-md text-[14px] transition hover:opacity-90"
            >
                Solicitar Cotización
            </a>

            <!-- Mobile Button -->
            <button
                id="menu-toggle"
                class="lg:hidden relative w-8 h-8 flex flex-col justify-center items-center"
                aria-label="Abrir menú"
            >
                <span
                    class="line1 absolute w-7 h-0.5 bg-white transition-all duration-300"
                ></span>

                <span
                    class="line2 absolute w-7 h-0.5 bg-white transition-all duration-300"
                ></span>

                <span
                    class="line3 absolute w-7 h-0.5 bg-white transition-all duration-300"
                ></span>
            </button>
        </div>
    </div>

    <!-- Mobile Menu -->
    <div
        id="mobile-menu"
        class="lg:hidden overflow-hidden max-h-0 transition-all duration-500"
    >
        <nav class="px-6 pb-8">
            <ul class="flex flex-col items-center gap-6">
                {
                    links.map((link) => (
                        <li>
                            <a
                                href={link.href}
                                class="mobile-link text-white text-lg font-medium"
                            >
                                {link.label}
                            </a>
                        </li>
                    ))
                }

                <li class="w-full max-w-xs pt-4">
                    <a
                        href="#contact"
                        class="flex justify-center bg-(--color-accent) text-white font-semibold py-4 rounded-md"
                    >
                        Solicitar Cotización
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</header>

<script>
    const button = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const header = document.getElementById("site-header");

    function updateHeaderBackground() {
        if (!header) return;

        if (window.scrollY > 20 || header.classList.contains("menu-open")) {
            header.classList.add("scrolled");
        } else {
            header.classList.remove("scrolled");
        }
    }

    function closeMenu() {
        button?.classList.remove("active");
        menu?.classList.remove("open");
        header?.classList.remove("menu-open");

        updateHeaderBackground();
    }

    button?.addEventListener("click", () => {
        button.classList.toggle("active");
        menu?.classList.toggle("open");
        header?.classList.toggle("menu-open");

        updateHeaderBackground();
    });

    document.querySelectorAll(".mobile-link").forEach((link) => {
        link.addEventListener("click", closeMenu);
    });

    window.addEventListener("scroll", updateHeaderBackground);

    updateHeaderBackground();
</script>

<style>
    .line1 {
        transform: translateY(-8px);
    }

    .line3 {
        transform: translateY(8px);
    }

    #menu-toggle.active .line1 {
        transform: rotate(45deg);
    }

    #menu-toggle.active .line2 {
        opacity: 0;
    }

    #menu-toggle.active .line3 {
        transform: rotate(-45deg);
    }

    #mobile-menu.open {
        max-height: 500px;
    }

    #site-header {
        transition:
            background-color 0.3s ease,
            backdrop-filter 0.3s ease;
    }

    #site-header.scrolled,
    #site-header.menu-open {
        background: rgba(4, 23, 54, 0.9);
        backdrop-filter: blur(12px);
    }
</style>
