---
const links = [
    { href: "#services", label: "Servicios" },
    { href: "#culture", label: "Nuestra Cultura" },
    { href: "#identity", label: "Identidad" },
    { href: "#contact", label: "Contacto" },
];
---

<header class="absolute top-0 left-0 w-full z-50">
    <div class="max-w-7xl mx-auto px-12">
        <div class="h-28 flex items-center justify-between">
            <!-- Logo -->
            <a href="/">
                <img
                    src="/logo-white.svg"
                    alt="Vita Global Cargo"
                    class="h-14 w-auto"
                />
            </a>

            <!-- Navegación -->
            <nav class="hidden lg:block">
                <ul class="flex items-center gap-16">
                    {
                        links.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="text-white font-medium hover:opacity-80 transition text-[14px]"
                                >
                                    {link.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>

            <!-- CTA -->
            <a
                href="#contact"
                class="hidden lg:flex items-center justify-center
               bg-(--color-accent) hover:bg-red-600
               text-white font-semibold
               px-10 py-4 rounded-md
               text-[14px]
               transition"
            >
                Solicitar Cotización
            </a>
        </div>
    </div>
</header>
